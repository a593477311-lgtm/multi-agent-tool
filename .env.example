# ===========================================
# Multi-Agent Tool 环境变量配置
# ===========================================
# 请复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# -------------------------------------------
# 平台选择
# -------------------------------------------
# 可选值: nvidia / siliconflow / aliyun
PLATFORM=siliconflow

# -------------------------------------------
# 硅基流动 (SiliconFlow) 配置
# -------------------------------------------
# 获取地址: https://cloud.siliconflow.cn/
siliconflow_API_KEY=your_siliconflow_api_key_here
siliconflow_BASE_URL=https://api.siliconflow.cn/v1

# -------------------------------------------
# NVIDIA NIM 配置
# -------------------------------------------
# 获取地址: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# -------------------------------------------
# 阿里云百炼配置
# -------------------------------------------
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
ALIYUN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# -------------------------------------------
# 默认模型配置
# -------------------------------------------
# NVIDIA 平台可选模型:
#   - z-ai/glm5
#   - deepseek-ai/deepseek-v3.2
#   - moonshotai/kimi-k2.5
#   - qwen/qwen3.5-397b-a17b
#
# 硅基流动平台可选模型:
#   - deepseek-ai/DeepSeek-V3.2
#
# 阿里云百炼平台可选模型:
#   - qwen3.5-plus
#   - glm-5
DEFAULT_MODEL=deepseek-ai/DeepSeek-V3.2

# -------------------------------------------
# 高级配置 (可选)
# -------------------------------------------
# 调试模式
DEBUG=false

# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# NVIDIA NIM 缓存配置
ENABLE_PREFIX_CACHE=true
NIM_KV_CACHE_HOST_OFFLOAD=false

# 模型价格配置 (可选，用于计算成本)
# MODEL_PRICE_INPUT=2.0
# MODEL_PRICE_OUTPUT=3.0
